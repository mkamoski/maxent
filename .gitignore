# ScriptConfig.json must ALWAYS be tracked (multiple patterns for safety)
!ScriptConfig.json
!**/ScriptConfig.json
!gui_runner/ScriptConfig.json
# Published outputs and portable bundles are never committed

# ========================================== 
# Operating System & IDE
# ==========================================
.vs/
.vscode/
*.user
*.DS_Store
Thumbs.db

