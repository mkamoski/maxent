# ==========================================
# Project Specific - MaxEnt GUI Runner
# ==========================================
# Don't commit the large EXE (users extract from ZIP or build it)
gui_runner_published/MaxEntRunner.exe
gui_runner_published/*.pdb
# But DO commit the ZIP (it's only 63 MB)
!gui_runner_published/MaxEntRunner.zip

# Ignore .NET build artifacts (anywhere in repo)
